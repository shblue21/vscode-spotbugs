{
  "name": "vscode-spotbugs",
  "displayName": "%displayName%",
  "description": "%description%",
  "version": "0.7.2",
  "publisher": "shblue21",
  "icon": "images/spotbugs_icon.png",
  "author": {
    "name": "shblue21",
    "email": "shblue21@naver.com",
    "url": "https://shblue21.github.io"
  },
  "engines": {
    "vscode": "^1.85.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/shblue21/vscode-spotbugs"
  },
  "homepage": "https://github.com/shblue21/vscode-spotbugs#readme",
  "bugs": {
    "url": "https://github.com/shblue21/vscode-spotbugs/issues"
  },
  "qna": false,
  "license": "MIT",
  "pricing": "Free",
  "categories": [
    "Linters",
    "Other"
  ],
  "keywords": [
    "java",
    "spotbugs",
    "findbugs",
    "static-analysis",
    "linter",
    "code-quality",
    "bug-detection",
    "code-scanning",
    "security",
    "sast",
    "java-linter",
    "java-static-analysis",
    "maven",
    "gradle",
    "sarif",
    "vscode"
  ],
  "main": "./out/extension.js",
  "l10n": "./l10n",
  "capabilities": {
    "virtualWorkspaces": false,
    "untrustedWorkspaces": {
      "supported": false,
      "description": "%capabilities.untrustedWorkspaces.description%"
    }
  },
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "spotbugs-container",
          "title": "%contributes.viewsContainers.activitybar.spotbugs-container.title%",
          "icon": "images/spotbugs_icon.png"
        }
      ]
    },
    "views": {
      "spotbugs-container": [
        {
          "id": "spotbugs-view",
          "name": "%contributes.views.spotbugs-container.spotbugs-view.name%"
        },
        {
          "id": "spotbugs-inspector-view",
          "name": "%contributes.views.spotbugs-container.spotbugs-inspector-view.name%",
          "type": "webview"
        },
        {
          "id": "spotbugs-plugins-view",
          "name": "%contributes.views.spotbugs-container.spotbugs-plugins-view.name%",
          "visibility": "collapsed"
        }
      ]
    },
    "configuration": [
      {
        "type": "object",
        "title": "%contributes.configuration.analysis.title%",
        "order": 0,
        "properties": {
          "spotbugs.analysis.effort": {
            "type": "string",
            "default": "default",
            "enum": [
              "min",
              "default",
              "max"
            ],
            "enumDescriptions": [
              "%contributes.configuration.spotbugs.analysis.effort.enumDescriptions.min%",
              "%contributes.configuration.spotbugs.analysis.effort.enumDescriptions.default%",
              "%contributes.configuration.spotbugs.analysis.effort.enumDescriptions.max%"
            ],
            "markdownDescription": "%contributes.configuration.spotbugs.analysis.effort.markdownDescription%",
            "scope": "window"
          },
          "spotbugs.analysis.priorityThreshold": {
            "type": "integer",
            "default": 9,
            "markdownDescription": "%contributes.configuration.spotbugs.analysis.priorityThreshold.markdownDescription%",
            "minimum": 1,
            "maximum": 20,
            "scope": "window"
          },
          "spotbugs.analysis.extraAuxClasspaths": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "default": [],
            "uniqueItems": true,
            "markdownDescription": "%contributes.configuration.spotbugs.analysis.extraAuxClasspaths.markdownDescription%",
            "scope": "window"
          },
          "spotbugs.plugins.paths": {
            "type": "array",
            "items": {
              "type": "string",
              "pattern": "^.*\\.jar$"
            },
            "default": [],
            "uniqueItems": true,
            "markdownDescription": "%contributes.configuration.spotbugs.plugins.paths.markdownDescription%",
            "scope": "window"
          }
        }
      },
      {
        "type": "object",
        "title": "%contributes.configuration.filters.title%",
        "order": 1,
        "properties": {
          "spotbugs.filters.includePaths": {
            "type": "array",
            "items": {
              "type": "string",
              "pattern": "^.*\\.xml$"
            },
            "default": [],
            "uniqueItems": true,
            "markdownDescription": "%contributes.configuration.spotbugs.filters.includePaths.markdownDescription%",
            "scope": "window"
          },
          "spotbugs.filters.excludePaths": {
            "type": "array",
            "items": {
              "type": "string",
              "pattern": "^.*\\.xml$"
            },
            "default": [],
            "uniqueItems": true,
            "markdownDescription": "%contributes.configuration.spotbugs.filters.excludePaths.markdownDescription%",
            "scope": "window"
          },
          "spotbugs.filters.excludeBaselineBugsPaths": {
            "type": "array",
            "items": {
              "type": "string",
              "pattern": "^.*\\.xml$"
            },
            "default": [],
            "uniqueItems": true,
            "markdownDescription": "%contributes.configuration.spotbugs.filters.excludeBaselineBugsPaths.markdownDescription%",
            "scope": "window"
          }
        }
      },
      {
        "type": "object",
        "title": "%contributes.configuration.results.title%",
        "order": 2,
        "properties": {
          "spotbugs.results.revealSourceOnSelection": {
            "type": "boolean",
            "default": true,
            "markdownDescription": "%contributes.configuration.spotbugs.results.revealSourceOnSelection.markdownDescription%",
            "scope": "window"
          }
        }
      }
    ],
    "commands": [
      {
        "command": "spotbugs.run",
        "title": "%contributes.commands.spotbugs.run.title%"
      },
      {
        "command": "spotbugs.runWorkspace",
        "title": "%contributes.commands.spotbugs.runWorkspace.title%",
        "icon": "$(bug)"
      },
      {
        "command": "spotbugs.revealFindingSource",
        "title": "%contributes.commands.spotbugs.revealFindingSource.title%",
        "icon": "$(go-to-file)"
      },
      {
        "command": "spotbugs.openFindingDetails",
        "title": "%contributes.commands.spotbugs.openFindingDetails.title%",
        "icon": "$(open-preview)"
      },
      {
        "command": "spotbugs.filterResults",
        "title": "%contributes.commands.spotbugs.filterResults.title%",
        "icon": "$(filter)"
      },
      {
        "command": "spotbugs.exportSarif",
        "title": "%contributes.commands.spotbugs.exportSarif.title%",
        "icon": "$(file-code)"
      },
      {
        "command": "spotbugs.exportHtml",
        "title": "%contributes.commands.spotbugs.exportHtml.title%",
        "icon": "$(file)"
      },
      {
        "command": "spotbugs.resetResults",
        "title": "%contributes.commands.spotbugs.resetResults.title%",
        "icon": "$(trash)"
      },
      {
        "command": "spotbugs.searchResults",
        "title": "%contributes.commands.spotbugs.searchResults.title%",
        "icon": "$(search)"
      },
      {
        "command": "spotbugs.clearSearch",
        "title": "%contributes.commands.spotbugs.clearSearch.title%",
        "icon": "$(clear-all)"
      },
      {
        "command": "spotbugs.groupResultsBy",
        "title": "%contributes.commands.spotbugs.groupResultsBy.title%",
        "icon": "$(group-by-ref-type)"
      },
      {
        "command": "spotbugs.sortResultsBy",
        "title": "%contributes.commands.spotbugs.sortResultsBy.title%",
        "icon": "$(sort-precedence)"
      },
      {
        "command": "spotbugs.openSettings",
        "title": "%contributes.commands.spotbugs.openSettings.title%",
        "icon": "$(gear)"
      },
      {
        "command": "spotbugs.refreshPluginInventory",
        "title": "%contributes.commands.spotbugs.refreshPluginInventory.title%",
        "icon": "$(refresh)"
      },
      {
        "command": "spotbugs.addPluginJars",
        "title": "%contributes.commands.spotbugs.addPluginJars.title%",
        "icon": "$(add)"
      },
      {
        "command": "spotbugs.removePluginJar",
        "title": "%contributes.commands.spotbugs.removePluginJar.title%",
        "icon": "$(trash)"
      }
    ],
    "menus": {
      "view/title": [
        {
          "command": "spotbugs.runWorkspace",
          "when": "view == spotbugs-view",
          "group": "navigation@1"
        },
        {
          "command": "spotbugs.searchResults",
          "when": "view == spotbugs-view",
          "group": "navigation@2"
        },
        {
          "command": "spotbugs.openSettings",
          "when": "view == spotbugs-view",
          "group": "navigation@99"
        },
        {
          "command": "spotbugs.exportSarif",
          "when": "view == spotbugs-view",
          "group": "2_spotbugs@1"
        },
        {
          "command": "spotbugs.filterResults",
          "when": "view == spotbugs-view",
          "group": "2_spotbugs@2"
        },
        {
          "command": "spotbugs.resetResults",
          "when": "view == spotbugs-view",
          "group": "2_spotbugs@3"
        },
        {
          "command": "spotbugs.exportHtml",
          "when": "view == spotbugs-view",
          "group": "2_spotbugs@4"
        },
        {
          "command": "spotbugs.groupResultsBy",
          "when": "view == spotbugs-view",
          "group": "3_results@1"
        },
        {
          "command": "spotbugs.sortResultsBy",
          "when": "view == spotbugs-view",
          "group": "3_results@2"
        },
        {
          "command": "spotbugs.clearSearch",
          "when": "view == spotbugs-view",
          "group": "3_results@3"
        },
        {
          "command": "spotbugs.revealFindingSource",
          "when": "view == spotbugs-inspector-view",
          "group": "navigation@1"
        },
        {
          "command": "spotbugs.addPluginJars",
          "when": "view == spotbugs-plugins-view",
          "group": "navigation@1"
        },
        {
          "command": "spotbugs.refreshPluginInventory",
          "when": "view == spotbugs-plugins-view",
          "group": "navigation@2"
        }
      ],
      "commandPalette": [
        {
          "command": "spotbugs.removePluginJar",
          "when": "false"
        }
      ],
      "explorer/context": [
        {
          "submenu": "spotbugs.context",
          "when": "resourceLangId == java || resourceExtname == .jar || explorerResourceIsFolder"
        }
      ],
      "view/item/context": [
        {
          "command": "spotbugs.revealFindingSource",
          "when": "view == spotbugs-view && viewItem == spotbugs.bug",
          "group": "navigation@1"
        },
        {
          "command": "spotbugs.openFindingDetails",
          "when": "view == spotbugs-view && viewItem == spotbugs.bug",
          "group": "navigation@2"
        },
        {
          "command": "spotbugs.exportSarif",
          "when": "view == spotbugs-view && (viewItem == spotbugs.category || viewItem == spotbugs.pattern || viewItem == spotbugs.group)",
          "group": "navigation@3"
        },
        {
          "command": "spotbugs.exportHtml",
          "when": "view == spotbugs-view && (viewItem == spotbugs.category || viewItem == spotbugs.pattern || viewItem == spotbugs.group)",
          "group": "navigation@4"
        },
        {
          "command": "spotbugs.removePluginJar",
          "when": "view == spotbugs-plugins-view && viewItem =~ /^spotbugs\\.plugin\\.(validated|duplicate-plugin-id|validation-failed|backend-error)$/",
          "group": "1_manage@1"
        }
      ],
      "spotbugs.context": [
        {
          "command": "spotbugs.run",
          "when": "!explorerResourceIsFolder",
          "group": "1_spotbugs@1"
        },
        {
          "command": "spotbugs.run",
          "when": "explorerResourceIsFolder",
          "group": "1_spotbugs@1"
        }
      ]
    },
    "submenus": [
      {
        "id": "spotbugs.context",
        "label": "%contributes.submenus.spotbugs.context.label%"
      }
    ],
    "javaExtensions": [
      "./server/com.spotbugs.runner.jar",
      "./server/spotbugs-runner-all.jar"
    ]
  },
  "scripts": {
    "clean": "rimraf out tsconfig.tsbuildinfo",
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p .",
    "watch": "tsc -p . --watch",
    "pretest": "npm run compile && npm run lint",
    "test:l0": "mocha \"out/test/**/L0.*.test.js\"",
    "test:l1:unit": "mocha \"out/test/**/L1.*.test.js\" --ignore \"out/test/**/*.vscode.test.js\"",
    "test:l1": "npm run test:l1:unit && npm run test:vscode",
    "test:unit": "npm run test:l0 && npm run test:l1:unit",
    "test:vscode": "node out/test/runTest.js",
    "test": "npm run test:l0 && npm run test:l1",
    "lint": "eslint src --ext ts",
    "format": "prettier --write \"src/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.ts\"",
    "l10n:export": "vscode-l10n-dev export -o ./l10n ./src",
    "build-server": "node scripts/buildJdtlsExt.js",
    "generate:sarif-fixture": "node scripts/generateSarifFixture.js"
  },
  "extensionDependencies": [
    "redhat.java"
  ],
  "devDependencies": {
    "@types/mocha": "^10.0.10",
    "@types/node": "^18.19.130",
    "@types/sanitize-html": "^2.16.1",
    "@types/vscode": "^1.85.0",
    "@typescript-eslint/eslint-plugin": "^8.36.0",
    "@typescript-eslint/parser": "^8.36.0",
    "@vscode/l10n-dev": "^0.0.35",
    "@vscode/test-electron": "^2.5.2",
    "eslint": "^9.39.2",
    "eslint-config-prettier": "^9.1.2",
    "eslint-plugin-prettier": "^5.5.4",
    "mocha": "^11.7.5",
    "prettier": "^3.6.2",
    "rimraf": "^6.1.2",
    "typescript": "^5.8.3"
  },
  "dependencies": {
    "fs-extra": "^11.3.3",
    "sanitize-html": "^2.17.1",
    "vscode-extension-telemetry-wrapper": "^0.15.3"
  }
}
